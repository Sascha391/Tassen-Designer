rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bestellungen: jeder Kunde darf eine anlegen, nur der eingeloggte Admin darf lesen/ändern
    match /tassen_bestellungen/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Produkte: jeder darf lesen (für die Kundenseite), nur der Admin darf ändern
    match /tassen_produkte/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
